<?xml version="1.0" encoding="UTF-8"?>
<included>
    <conversionRule conversionWord="maskMessage" 
                    converterClass="com.yourorg.platform.foculist.tenancy.logging.LogMaskingConverter" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [${spring.application.name:-},%X{traceId:-},%X{spanId:-},%X{tenantId:-}] %maskMessage%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</included>
