      },
      "targets": [
        {
          "expr": "{application=~\"$application\"} | json | line_format \"{{.level}} [{{.application}}] {{.message}}\"",
          "refId": "A"
        }
      ],
      "title": "Raw Logs",
      "type": "logs"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 3,
      "targets": [
        {
          "expr": "count_over_time({application=~\"$application\"} |= \"ERROR\" [1m])",
          "legendFormat": "{{application}} errors",
          "refId": "A"
        }
      ],
      "title": "Error Count (per minute)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
